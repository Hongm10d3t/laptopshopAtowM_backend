# Copy file này thành .env rồi điền giá trị thật. Không commit file .env.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=laptophub
DB_USERNAME=changeme
DB_PASSWORD=changeme

# JWT signing key (HS256, tối thiểu 32 byte). Giá trị "changeme" cố tình quá
# ngắn để app từ chối khởi động (WeakKeyException) nếu quên đổi. Tạo secret
# thật bằng: openssl rand -base64 32
JWT_SECRET=changeme

# Dùng ở giai đoạn chatbot (tư vấn sản phẩm bằng AI)
OPENAI_API_KEY=changeme
